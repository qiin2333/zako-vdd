{
  "configurations": [
    {
      "inheritEnvironments": [
        "msvc_x64"
      ],
      "name": "x64-Debug",
      "includePath": [
        "${env.INCLUDE}",
        "${workspaceRoot}\\**"
      ],
      "defines": [
        "_WIN64",
        "_DEBUG",
        "UMDF_DRIVER",
        "IDDCX_VERSION_MAJOR=1",
        "IDDCX_VERSION_MINOR=10",
        "IDDCX_MINIMUM_VERSION_REQUIRED=3",
        "UNICODE",
        "_UNICODE"
      ],
      "intelliSenseMode": "windows-msvc-x64"
    }
  ]
}
